# Supabase (https://supabase.com)
# Без этих переменных приложение работает в демо-режиме (localStorage).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Metered TURN (https://www.metered.ca) — для видеозвонков через мобильный интернет (CGNAT).
# Необязательно: без них звонки работают только через STUN (часто достаточно в одной сети).
VITE_METERED_DOMAIN=your-domain.metered.live
VITE_METERED_API_KEY=your-metered-api-key
